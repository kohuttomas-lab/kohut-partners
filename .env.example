# Stripe — test mode. Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored, so secrets never reach the repo.
# Get test keys at https://dashboard.stripe.com/test/apikeys

# Server-only secret key (REQUIRED for checkout).
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret (REQUIRED to confirm payments / fulfilment).
# Local dev: run `stripe listen --forward-to localhost:3200/api/stripe/webhook`
# and copy the whsec_... it prints. Production: set it on the dashboard endpoint.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional — only needed if you switch to embedded Stripe Elements.
# Hosted Checkout (the current setup) does NOT need this.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
